name: Build Kernel
on: [push]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Source Code
        uses: actions/checkout@v4

      - name: Setup Toolchain
        run: sudo apt-get update && sudo apt-get install gcc-arm-linux-gnueabi ccache

      - name: Build Kernel
        run: |
          export ARCH=arm
          export CROSS_COMPILE=arm-linux-gnueabi-
          export USE_CCACHE=1
          make O5lteswa_LP_defconfig
          make -j$(nproc)

      - name: Upload zImage
        uses: actions/upload-artifact@v4
        with:
          name: zImage
          path: arch/arm/boot/zImage
